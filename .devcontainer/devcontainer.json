{
    "name": "Rust GUI Dev",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "remoteUser": "ubuntu",

    "runArgs": [
        "--net=host",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-e", "WAYLAND_DISPLAY=${localEnv:WAYLAND_DISPLAY}",
        "-e", "XDG_RUNTIME_DIR=/tmp/xdg-runtime",
        "--device=/dev/dri"
    ],

    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
        "source=${localEnv:XDG_RUNTIME_DIR}/${localEnv:WAYLAND_DISPLAY},target=/tmp/xdg-runtime/${localEnv:WAYLAND_DISPLAY},type=bind"
    ],

    "postCreateCommand": "rustc --version && cargo --version"
}
